{
  "name": "@torinojs-swarm/db",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/src/index.js"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./dist/src/schema/index.js"
    },
    "./schema/auth": {
      "types": "./src/schema/auth.ts",
      "default": "./dist/src/schema/auth.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "check-types": "tsc -b",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@effect/sql": "0.49.0",
    "@effect/sql-drizzle": "0.48.1",
    "@effect/sql-pg": "0.50.3",
    "@neondatabase/serverless": "^1.0.2",
    "dotenv": "catalog:",
    "@torinojs-swarm/env": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "effect": "catalog:",
    "pg": "^8.16.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@torinojs-swarm/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.31.8",
    "typescript": "catalog:"
  }
}
