{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_SERVER_URL",
        "DATABASE_URL",
        "DATABASE_URL_DIRECT",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "UPSTASH_REDIS_PORT",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "CORS_ORIGIN",
        "AI_PROVIDER",
        "AI_GATEWAY_MODEL",
        "AI_OPENAI_API_KEY",
        "AI_OPENAI_BASE_URL",
        "AI_OPENAI_MODEL",
        "NODE_ENV"
      ]
    }
  }
}
