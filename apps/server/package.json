{
  "name": "@reaping/server",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./app": {
      "default": "./src/app.ts"
    }
  },
  "scripts": {
    "build": "rolldown -c",
    "check-types": "tsc -b",
    "deploy": "vercel",
    "deploy:prod": "vercel --prod",
    "lint": "oxlint",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "pretest": "bun run --cwd ../../packages/env build && bun run --cwd ../../packages/db build && bun run --cwd ../../packages/auth build && bun run --cwd ../../packages/api build",
    "start": "bun run dist/index.mjs",
    "test": "bun test ./src/app.smoke.test.ts"
  },
  "dependencies": {
    "@reaping/ai": "workspace:*",
    "@reaping/api": "workspace:*",
    "@reaping/env": "workspace:*",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "effect": "catalog:",
    "elysia": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@elysiajs/eden": "^1.4.8",
    "@reaping/config": "workspace:*",
    "@types/bun": "catalog:",
    "rolldown": "^1.0.0-rc.7",
    "typescript": "catalog:"
  }
}
