{
  "name": "torinojs-swarm",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "effect": "^3.19.19",
      "elysia": "^1.4.21",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4",
      "better-auth": "1.5.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:server": "turbo run dev --filter=server",
    "dev:web": "turbo run dev --filter=web",
    "build:server": "turbo run build --filter=server",
    "build:web": "turbo run build --filter=web",
    "check-types:server": "turbo run check-types --filter=server",
    "check-types:web": "turbo run check-types --filter=web",
    "lint": "turbo run lint",
    "lint:server": "turbo run lint --filter=server",
    "lint:web": "turbo run lint --filter=web",
    "test": "turbo run test",
    "test:server": "turbo run test --filter=server",
    "db:push": "turbo run db:push --filter=@torinojs-swarm/db",
    "db:studio": "turbo run db:studio --filter=@torinojs-swarm/db",
    "db:generate": "turbo run db:generate --filter=@torinojs-swarm/db",
    "db:migrate": "turbo run db:migrate --filter=@torinojs-swarm/db",
    "check": "turbo run lint check-types"
  },
  "dependencies": {
    "@torinojs-swarm/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@torinojs-swarm/config": "workspace:*",
    "@types/bun": "catalog:",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.5"
}
